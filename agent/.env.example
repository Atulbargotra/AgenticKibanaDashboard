ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601
KIBANA_SPACE=default

# Local experiments only. OpenRouter's free router may choose different models over time.
OPENROUTER_API_KEY=replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free

AGENT_DRY_RUN=true
AGENT_REQUIRE_REVIEW=false
ALLOW_DETERMINISTIC_FALLBACK=false
SERVICE_NAME=checkout-service
DEPLOYMENT_ENVIRONMENT=local
LOGS_INDEX_PATTERN=logs-springboot-local*
LOGS_DATA_VIEW_TITLE=logs-springboot-local*
METRICS_DATA_VIEW_TITLE=metrics-springboot-local*
TRACES_DATA_VIEW_TITLE=traces-springboot-local*
PATTERN_WINDOW_MINUTES=15
DETECTION_INTERVAL_SECONDS=60
ERROR_SPIKE_THRESHOLD=5
FINDING_COOLDOWN_SECONDS=600
